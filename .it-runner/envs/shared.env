# Legacy repos root (contains nas-packages / nas-packages-luci / openwrt-app-actions / openwrt-app-meta).
# This is what `syncapps.yaml:legacy_root` points to (directly or via env expansion).
LEGACY_ROOT=/projects/workspace-linkease-ubuntu/openwrt-apps

# External data directory (not in repo). Used for runner logs/cache if you choose to configure it.
DATA_ROOT=/tmp/istoreos-app-hub-data
